# ============================================
# GDPR Scanner Worker — Environment Variables
# ============================================
# Copy this file to .env.worker and fill in values
#
# Usage:
#   docker run --env-file .env.worker gdpr-scanner-worker
# ============================================

# PostgreSQL connection (same database as API server)
DATABASE_URL=postgresql://user:password@host:5432/gdpr_audit

# Worker authentication token (must match API server's WORKER_AUTH_TOKEN)
WORKER_AUTH_TOKEN=your-secure-token-here

# Cloud Run port (default: 8080)
PORT=8080

# Max concurrent scans per worker instance (default: 1)
WORKER_MAX_CONCURRENT=1

# Node environment
NODE_ENV=production

# ============================================
# Hybrid Queue Mode (QUEUE_TYPE=hybrid)
# ============================================
# These settings configure when overflow to Cloud Run is triggered.
# The local Redis/BullMQ worker handles jobs normally.
# Cloud Run only activates when thresholds are exceeded.

# Trigger overflow when queue depth exceeds this number (default: 2)
OVERFLOW_QUEUE_THRESHOLD=2

# Trigger overflow when oldest job waits longer than N seconds (default: 120)
OVERFLOW_WAIT_THRESHOLD_SEC=120

# How often to check for overflow conditions, in ms (default: 15000)
OVERFLOW_CHECK_INTERVAL_MS=15000

# Enable/disable overflow entirely (default: true)
OVERFLOW_ENABLED=true

# Cloud Run worker URL (only needed for hybrid/cloudrun modes)
WORKER_URL=https://gdpr-scanner-worker-xxxxx-xx.a.run.app
