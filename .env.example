# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gdpr_audit?schema=public"

# Email (Resend)
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="PolicyTracker <noreply@policytracker.eu>"
ADMIN_EMAIL="admin@example.com"

# App
PORT=3000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:4200"

# Queue System (optional)
QUEUE_TYPE=postgres
# REDIS_URL="redis://localhost:6379"
# WORKER_CONCURRENCY=1

# Scanner runtime tuning (optional)
# Maximum wall-clock time for a single scan before it aborts.
# Default 120000 (2 min). Increase for slow / heavy targets, decrease
# to fail fast in CI smoke tests.
# SCAN_TIMEOUT_MS=120000
#
# Per-IP rate limits for scanner endpoints. Two windows per route
# (short = burst, medium = hourly cap). Defaults match historical
# behaviour and protect against abuse on the public scan endpoint.
# Format: TTL in milliseconds, LIMIT in requests.
# SCAN_RATE_SHORT_TTL_MS=60000
# SCAN_RATE_SHORT_LIMIT=3
# SCAN_RATE_MEDIUM_TTL_MS=3600000
# SCAN_RATE_MEDIUM_LIMIT=20
# SCAN_QUEUE_SHORT_TTL_MS=60000
# SCAN_QUEUE_SHORT_LIMIT=5
# SCAN_QUEUE_MEDIUM_TTL_MS=3600000
# SCAN_QUEUE_MEDIUM_LIMIT=30

# Launch pricing campaign (optional)
# Identifier used to scope LaunchPurchase rows + Redis counter keys.
# Change when starting a new campaign so old slots aren't reused.
# LAUNCH_CAMPAIGN_ID=launch-2026
#
# Maximum price (€) — slot 1 = €1, slot 2 = €2, ..., capped at this.
# LAUNCH_MAX_PRICE=99

# Stripe (production only)
# STRIPE_SECRET_KEY="sk_xxxxxxxxxxxx"
# STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxx"

# Cloudflare Turnstile (captcha)
# Secret Key ONLY — the Site Key lives in the frontend env.
# Obtain from: Cloudflare Dashboard → Turnstile → <site> → Settings.
# If unset in non-production, captcha verification is skipped (dev-friendly).
# In production this MUST be set, otherwise all captcha checks fail closed.
TURNSTILE_SECRET_KEY=""

# Sentry (production error tracking)
# When SENTRY_DSN is empty the SDK is a complete no-op (safe in dev).
# In production a startup warning is logged if this is unset.
# Obtain from: sentry.io → Project → Settings → Client Keys (DSN).
# SENTRY_DSN=https://xxxxxxxx@o0.ingest.sentry.io/0000000
#
# Performance/profiling sample rates (0..1). Defaults: 0.1 in prod,
# 1.0 in dev. Free tier (5k transactions/mo) is fine at 0.1 for the
# current scan volume — raise only if you need higher resolution on a
# specific incident.
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.1
